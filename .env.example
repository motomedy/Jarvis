# Required API Keys
ANTHROPIC_API_KEY=OLLAMA
FISH_API_KEY=3ba15c2780804897a48a47716bb24e30

# Speech-to-text provider fallback: fish
# Chrome Web Speech API remains the primary path in the frontend when available
STT_PROVIDER=fish

# Optional: Fish Audio voice model (defaults to JARVIS MCU voice)
 FISH_VOICE_ID=3ba15c2780804897a48a47716bb24e30

# Optional: Your name (JARVIS will address you by name)
USER_NAME=Medy

# Optional: Specific Apple Calendar accounts to read (comma-separated emails)
# If not set, JARVIS reads ALL calendars from Apple Calendar
CALENDAR_ACCOUNTS=
